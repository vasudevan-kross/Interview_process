@router.get("/candidates/token/{token}", summary="Get candidate by token (public)")
async def get_candidate_by_token(token: str):
    """
    Public endpoint for shareable link page.
    BACKWARD COMPATIBLE: Returns VAPI config if campaign exists, otherwise null

    Returns:
    - vapi_config: Full VAPI configuration (if campaign exists) or None (legacy)
    - Candidate details (name, is_fresher, status, etc.)
    """
    try:
        service = get_voice_screening_service()
        candidate = await service.get_candidate_by_token(token)

        response = {
            "id": candidate["id"],
            "interview_token": candidate["interview_token"],
            "name": candidate["name"],
            "status": candidate["status"],
            "is_fresher": candidate.get("is_fresher", False),  # For backward compatibility
            "campaign_id": candidate.get("campaign_id"),
            "vapi_config": None,  # Default to None (use env ASSISTANT_ID)
            "system_prompt_preview": None
        }

        # NEW WORKFLOW: If campaign exists, fetch dynamic VAPI config
        if candidate.get("campaign_id"):
            try:
                campaign = service.client.table("voice_screening_campaigns").select(
                    "vapi_config, generated_system_prompt"
                ).eq("id", candidate["campaign_id"]).single().execute()

                if campaign.data:
                    response["vapi_config"] = campaign.data["vapi_config"]
                    response["system_prompt_preview"] = campaign.data["generated_system_prompt"][:200] + "..."
                    logger.info(f"Returning dynamic VAPI config for campaign: {candidate['campaign_id']}")
            except Exception as campaign_err:
                logger.warning(f"Failed to fetch campaign config: {campaign_err}")
                # Continue with vapi_config = None (fallback to legacy)

        # OLD WORKFLOW: If no campaign or campaign fetch failed, vapi_config remains None
        # Frontend will fall back to VAPI_ASSISTANT_ID from environment
        else:
            logger.info("Returning legacy candidate (no campaign)")

        return response

    except ValueError:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Candidate not found"
        )
    except Exception as e:
        logger.error(f"Error getting candidate by token: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail="Failed to get candidate"
        )


@router.post("/candidates/token/{token}/start-call", summary="Mark call started (public)")
async def start_call(token: str, call_id: Optional[str] = None):
    """Mark a candidate's call as in progress."""
    try:
        service = get_voice_screening_service()
        await service.update_candidate_status(token, "in_progress", call_id)
        return {"status": "in_progress"}

    except Exception as e:
        logger.error(f"Error starting call: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail="Failed to start call"
        )


@router.post("/candidates/token/{token}/fetch-call-data", summary="Fetch call data from VAPI (public)")
async def fetch_call_data(token: str, call_id: str):
    """
    Fetch transcript, recording, and structured data from VAPI API after call ends.
    This replaces webhook-based data collection with direct API polling.
    """
    import httpx
    from app.core.config import get_settings

    settings = get_settings()

    if not settings.VAPI_PRIVATE_KEY:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="VAPI not configured"
        )

    try:
        logger.info(f"Fetching call data from VAPI for call_id: {call_id}")

        # Fetch call data from VAPI API
        async with httpx.AsyncClient() as client:
            response = await client.get(
                f"https://api.vapi.ai/call/{call_id}",
                headers={
                    "Authorization": f"Bearer {settings.VAPI_PRIVATE_KEY}"
                },
                timeout=30.0
            )

            if response.status_code == 404:
                raise HTTPException(
                    status_code=status.HTTP_404_NOT_FOUND,
                    detail="Call not found in VAPI"
                )

            if response.status_code != 200:
                logger.error(f"VAPI API error: {response.status_code} - {response.text}")
                raise HTTPException(
                    status_code=status.HTTP_502_BAD_GATEWAY,
                    detail=f"VAPI API error: {response.status_code}"
                )

            call_data = response.json()

        # Extract data from VAPI response
        transcript = call_data.get("transcript", "")
        recording_url = call_data.get("recordingUrl", "")
        structured_data = call_data.get("analysis", {}).get("structuredData", {})
        call_status = call_data.get("status", "")

        logger.info(f"VAPI call data retrieved:")
        logger.info(f"  - Status: {call_status}")
        logger.info(f"  - Transcript length: {len(transcript)} chars")
        logger.info(f"  - Recording URL: {'Present' if recording_url else 'Missing'}")
        logger.info(f"  - Structured data fields: {list(structured_data.keys())}")

        # If call is still in progress, return pending status
        if call_status in ["queued", "ringing", "in-progress"]:
            return {
                "status": "pending",
                "message": "Call is still in progress or processing"
            }

        # Get service and find candidate
        service = get_voice_screening_service()

        # Find candidate by token and call_id
        candidate_result = service.client.table("voice_candidates").select(
            "*, voice_screening_campaigns(generated_schema)"
        ).eq("interview_token", token).eq("call_id", call_id).single().execute()

        if not candidate_result.data:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Candidate not found"
            )

        candidate = candidate_result.data

        # Download and store recording permanently in Supabase Storage
        recording_service = get_vapi_recording_service()
        stored_recording_url = recording_url
        stored_transcript_url = None

        if recording_url:
            logger.info(f"Downloading recording from VAPI: {recording_url}")
            permanent_recording_url = await recording_service.download_and_store_recording(
                recording_url=recording_url,
                candidate_id=candidate["id"],
                call_id=call_id
            )
            if permanent_recording_url:
                stored_recording_url = permanent_recording_url
                logger.info(f"Recording stored permanently: {permanent_recording_url}")

        if transcript:
            logger.info("Storing transcript in Supabase Storage")
            stored_transcript_url = await recording_service.download_and_store_transcript(
                transcript=transcript,
                candidate_id=candidate["id"],
                call_id=call_id
            )

        # Prepare update data
        update_data = {
            "status": "completed",
            "transcript": transcript,
            "recording_url": stored_recording_url,
            "transcript_url": stored_transcript_url
        }

        # Campaign-based dynamic field mapping
        if candidate.get("voice_screening_campaigns"):
            campaign_schema = candidate["voice_screening_campaigns"]["generated_schema"]
            for field_name in campaign_schema.keys():
                if field_name in structured_data:
                    update_data[field_name] = structured_data[field_name]
            logger.info(f"Campaign-based mapping: {len(campaign_schema)} fields expected")
        else:
            # Legacy static field mapping
            field_mapping = {
                "gender": "gender",
                "current_work_location": "current_work_location",
                "native_location": "native_location",
                "current_employer": "current_employer",
                "work_type": "work_type",
                "employment_type": "employment_type",
                "current_role": "current_role",
                "expertise_in": "expertise_in",
                "total_experience": "total_experience",
                "certifications": "certifications",
                "projects_handled": "projects_handled",
                "current_ctc": "current_ctc",
                "expected_ctc": "expected_ctc",
                "notice_period": "notice_period",
                "serving_notice_period": "serving_notice_period",
                "tentative_joining_date": "tentative_joining_date",
                "existing_offers": "existing_offers",
                "available_interview_time": "available_interview_time",
                "current_team_size": "current_team_size",
                "current_shift_timing": "current_shift_timing",
                "reason_for_leaving": "reason_for_leaving"
            }
            for vapi_field, db_field in field_mapping.items():
                if vapi_field in structured_data:
                    update_data[db_field] = structured_data[vapi_field]

        # Update candidate record (latest call data)
        service.client.table("voice_candidates").update(update_data).eq(
            "id", candidate["id"]
        ).execute()

        # Save to call history table
        call_history_data = {
            "candidate_id": candidate["id"],
            "call_id": call_id,
            "status": "completed",
            "ended_at": call_data.get("endedAt"),
            "started_at": call_data.get("startedAt"),
            "transcript": transcript,
            "recording_url": stored_recording_url,
            "transcript_url": stored_transcript_url,
            "structured_data": structured_data,
            "call_type": "test",  # You can make this dynamic later
            "vapi_cost_cents": call_data.get("cost"),
            "vapi_duration_minutes": call_data.get("duration"),
            "vapi_metadata": {
                "model": call_data.get("model"),
                "voice_provider": call_data.get("voice", {}).get("provider"),
                "transcriber_provider": call_data.get("transcriber", {}).get("provider")
            }
        }

        service.client.table("voice_call_history").insert(call_history_data).execute()

        logger.info(f"✅ Successfully updated candidate {candidate['id']} with call data")
        logger.info(f"  - Transcript: {'Stored' if transcript else 'Missing'}")
        logger.info(f"  - Recording: {'Stored' if stored_recording_url else 'Missing'}")
        logger.info(f"  - Fields updated: {len(update_data)}")
        logger.info(f"  - Call history saved: {call_id}")

        return {
            "status": "success",
            "message": "Call data fetched and stored successfully",
            "has_transcript": bool(transcript),
            "has_recording": bool(stored_recording_url),
            "fields_updated": len(update_data),
            "call_history_id": call_id
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching call data: {e}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to fetch call data: {str(e)}"
        )


@router.get("/candidates/{candidate_id}/call-history", summary="Get call history for a candidate")
async def get_call_history(
    candidate_id: str,
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Get all call history for a candidate, ordered by most recent first.
    Returns transcript, recording, structured data for each call.
    """
    try:
        service = get_voice_screening_service()

        # Verify candidate belongs to user
        candidate_result = service.client.table("voice_candidates").select("id, created_by").eq(
            "id", candidate_id
        ).single().execute()

        if not candidate_result.data:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Candidate not found"
            )

        if candidate_result.data["created_by"] != current_user_id:
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail="Not authorized to view this candidate's call history"
            )

        # Fetch call history
        history_result = service.client.table("voice_call_history").select("*").eq(
            "candidate_id", candidate_id
        ).order("created_at", desc=True).execute()

        return {
            "candidate_id": candidate_id,
            "total_calls": len(history_result.data) if history_result.data else 0,
            "calls": history_result.data or []
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error getting call history: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to get call history: {str(e)}"
        )


@router.delete("/candidates/{candidate_id}", summary="Delete a voice candidate")
async def delete_candidate(
    candidate_id: str,
    current_user_id: str = Depends(get_current_user_id)
):
    """Delete a candidate record."""
    try:
        service = get_voice_screening_service()
        return await service.delete_candidate(candidate_id, current_user_id)

    except ValueError as e:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=str(e)
        )
    except Exception as e:
        logger.error(f"Error deleting candidate: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to delete candidate: {str(e)}"
        )


@router.post("/webhook", summary="Vapi end-of-call webhook")
async def vapi_webhook(request: Request):
    """
    Webhook endpoint for Vapi to send end-of-call reports.
    BACKWARD COMPATIBLE: Supports both campaign-based and legacy candidates

    - Campaign candidates: Uses dynamic field schema from campaign
    - Legacy candidates: Uses static field mapping
    """
    try:
        body = await request.json()
        logger.info(f"Received Vapi webhook: {json.dumps(body, indent=2)[:500]}")

        message = body.get("message", {})
        msg_type = message.get("type", "")

        # Handle end-of-call report
        if msg_type == "end-of-call-report":
            call_id = message.get("call", {}).get("id", "")

            if not call_id:
                logger.warning("Webhook missing call ID")
                return {"status": "ignored", "reason": "no call_id"}

            structured_data = message.get("analysis", {}).get("structuredData", {})
            transcript = message.get("transcript", "")
            recording_url = message.get("recordingUrl", "")

            # Enhanced logging for debugging
            logger.info(f"Webhook data for call {call_id}:")
            logger.info(f"  - Transcript length: {len(transcript) if transcript else 0} chars")
            logger.info(f"  - Recording URL: {recording_url if recording_url else 'MISSING'}")
            logger.info(f"  - Structured data fields: {list(structured_data.keys())}")

            service = get_voice_screening_service()

            # Find candidate by call_id (LEFT JOIN to support candidates without campaigns)
            try:
                candidate_result = service.client.table("voice_candidates").select(
                    "*, voice_screening_campaigns(generated_schema)"
                ).eq("call_id", call_id).single().execute()

                if not candidate_result.data:
                    logger.warning(f"No candidate found for call_id: {call_id}")
                    return {"status": "candidate_not_found"}

                candidate = candidate_result.data

            except Exception as find_error:
                logger.error(f"Error finding candidate: {find_error}")
                return {"status": "error", "message": "Candidate not found"}

            # Download and store recording permanently in Supabase Storage
            recording_service = get_vapi_recording_service()
            stored_recording_url = recording_url  # Default to VAPI URL
            stored_transcript_url = None

            if recording_url:
                logger.info(f"Downloading recording from VAPI: {recording_url}")
                permanent_recording_url = await recording_service.download_and_store_recording(
                    recording_url=recording_url,
                    candidate_id=candidate["id"],
                    call_id=call_id
                )
                if permanent_recording_url:
                    stored_recording_url = permanent_recording_url
                    logger.info(f"Recording stored permanently: {permanent_recording_url}")
                else:
                    logger.warning("Failed to store recording permanently, using VAPI URL")

            if transcript:
                logger.info("Storing transcript in Supabase Storage")
                stored_transcript_url = await recording_service.download_and_store_transcript(
                    transcript=transcript,
                    candidate_id=candidate["id"],
                    call_id=call_id
                )

            # Base update data (always included)
            update_data = {
                "status": "completed",
                "transcript": transcript,
                "recording_url": stored_recording_url,  # Use permanent URL
                "transcript_url": stored_transcript_url  # New field for transcript file
            }

            # NEW WORKFLOW: Campaign-based dynamic field mapping
            if candidate.get("voice_screening_campaigns"):
                campaign_schema = candidate["voice_screening_campaigns"]["generated_schema"]

                # Map only fields defined in campaign schema
                for field_name in campaign_schema.keys():
                    if field_name in structured_data:
                        update_data[field_name] = structured_data[field_name]

                logger.info(f"Webhook: Campaign-based mapping, {len(campaign_schema)} fields expected, {len([f for f in campaign_schema.keys() if f in structured_data])} fields extracted")
                workflow = "campaign"

            # OLD WORKFLOW: Legacy static schema mapping
            else:
                # Use existing hardcoded field mapping for backward compatibility
                extracted_data = {
                    "transcript": transcript,
                    "recordingUrl": recording_url,
                    "structuredData": structured_data,
                }

                # Call existing service method (maintains backward compatibility)
                await service.update_candidate_from_webhook(call_id, extracted_data)

                logger.info(f"Webhook: Legacy mapping completed for call {call_id}")
                return {"status": "processed", "workflow": "legacy"}

            # Update candidate (for campaign workflow)
            try:
                service.client.table("voice_candidates").update(update_data).eq(
                    "call_id", call_id
                ).execute()

                logger.info(f"✅ Updated candidate from call {call_id}")
                logger.info(f"  - Fields updated: {list(update_data.keys())}")
                logger.info(f"  - Transcript stored: {'Yes' if update_data.get('transcript') else 'No'}")
                logger.info(f"  - Recording URL stored: {'Yes' if update_data.get('recording_url') else 'No'}")
                logger.info(f"  - Transcript URL stored: {'Yes' if update_data.get('transcript_url') else 'No'}")

                return {
                    "status": "processed",
                    "fields_updated": len(update_data),
                    "workflow": workflow
                }

            except Exception as update_error:
                logger.error(f"Error updating candidate: {update_error}")
                return {"status": "error", "message": "Failed to update candidate"}

        # Handle status updates
        elif msg_type == "status-update":
            call_status = message.get("status", "")
            logger.info(f"Call status update: {call_status}")
            return {"status": "acknowledged"}

        return {"status": "ignored", "type": msg_type}

    except Exception as e:
        logger.error(f"Error processing Vapi webhook: {e}", exc_info=True)
        # Always return 200 to Vapi to prevent retries
        return {"status": "error", "message": str(e)}


@router.post("/generate-questions", response_model=QuestionGenerationResponse, summary="Generate interview questions using AI")
async def generate_questions(
    request: QuestionGenerationRequest,
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Generate interview questions using Ollama AI based on job role and candidate type.

    This uses the Mistral:7b model to generate contextually relevant questions.
    """
    try:
        import ollama

        # Build prompt for question generation
        candidate_context = {
            "fresher": "entry-level candidate with 0-2 years of experience",
            "experienced": "senior professional with 5+ years of experience",
            "general": "candidate of any experience level"
        }.get(request.candidate_type.value, "candidate")

        system_prompt = f"""You are an expert HR interviewer. Generate {request.num_questions} specific, relevant interview questions for a {candidate_context} applying for the position of {request.job_role}.

Requirements:
- Questions should be clear and concise
- Focus on skills, experience, and fit for the role
- Include both technical and behavioral questions
- Avoid yes/no questions
- Make questions conversational for voice interviews

Return ONLY a JSON array of questions, nothing else. Format: ["question1", "question2", ...]"""

        logger.info(f"Generating {request.num_questions} questions for {request.job_role} ({request.candidate_type})")

        response = ollama.chat(
            model="mistral:7b",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": f"Generate {request.num_questions} interview questions for {request.job_role} position."}
            ],
            options={
                "temperature": 0.7,
                "seed": None  # Allow variation
            }
        )

        response_text = response["message"]["content"].strip()
        logger.info(f"Raw AI response: {response_text[:500]}...")

        # Extract JSON array from response with robust parsing
        import json
        import re

        questions = []

        # Strategy 1: Try to find and parse JSON array
        json_match = re.search(r'\[[\s\S]*\]', response_text)
        if json_match:
            questions_json = json_match.group(0)
            try:
                # Try direct JSON parse
                parsed_data = json.loads(questions_json)

                # Check if the parsed data is a list of dictionaries with 'question' field
                if isinstance(parsed_data, list) and len(parsed_data) > 0:
                    if isinstance(parsed_data[0], dict) and 'question' in parsed_data[0]:
                        # Extract the 'question' field from each dictionary
                        questions = [item['question'] for item in parsed_data if isinstance(item, dict) and 'question' in item]
                        logger.info("Strategy 1: Extracted questions from dictionary format")
                    elif isinstance(parsed_data[0], str):
                        # Already a list of strings
                        questions = parsed_data
                        logger.info("Strategy 1: Direct string list parse successful")
                    else:
                        questions = []
                else:
                    questions = []

            except json.JSONDecodeError as e:
                logger.warning(f"Strategy 1 failed: {e}")
                # Strategy 2: Try to repair common JSON issues
                try:
                    # Fix single quotes to double quotes
                    repaired = questions_json.replace("'", '"')
                    # Remove trailing commas before closing bracket
                    repaired = re.sub(r',(\s*\])', r'\1', repaired)
                    # Remove trailing commas before closing brace
                    repaired = re.sub(r',(\s*\})', r'\1', repaired)
                    parsed_data = json.loads(repaired)

                    # Check if it's dictionary format
                    if isinstance(parsed_data, list) and len(parsed_data) > 0:
                        if isinstance(parsed_data[0], dict) and 'question' in parsed_data[0]:
                            questions = [item['question'] for item in parsed_data if isinstance(item, dict) and 'question' in item]
                            logger.info("Strategy 2: Extracted questions from repaired dictionary format")
                        elif isinstance(parsed_data[0], str):
                            questions = parsed_data
                            logger.info("Strategy 2: Repaired JSON parse successful")
                        else:
                            questions = []
                    else:
                        questions = []
                except json.JSONDecodeError as e2:
                    logger.warning(f"Strategy 2 failed: {e2}")
                    questions = []

        # Strategy 3: Fallback - extract questions from text
        if not questions:
            logger.info("Using Strategy 3: Text extraction")
            # Split by newlines and extract anything that looks like a question
            lines = response_text.split('\n')
            for line in lines:
                line = line.strip()
                # Skip empty, JSON syntax, or very short lines
                if not line or line in ['[', ']', '{', '}'] or len(line) < 10:
                    continue
                # Remove common prefixes
                cleaned = re.sub(r'^[\d\.\-\*\•\)]+\s*', '', line)
                cleaned = cleaned.strip(' "\'`')
                # Remove trailing commas and quotes
                cleaned = re.sub(r'[,"\'\`]+$', '', cleaned)

                if cleaned and len(cleaned) > 15:  # Must be substantial
                    questions.append(cleaned)

            questions = questions[:request.num_questions]

        if not questions or len(questions) == 0:
            # Last resort: provide default questions
            logger.warning("All strategies failed, using default questions")
            questions = [
                f"Tell me about your experience as a {request.job_role}",
                f"What are your key skills relevant to this {request.job_role} position?",
                "What is your current work situation and availability?",
                "What are your salary expectations for this role?",
                "Why are you interested in this opportunity?"
            ][:request.num_questions]

        logger.info(f"Successfully extracted {len(questions)} questions")

        return QuestionGenerationResponse(
            questions=questions[:request.num_questions],  # Ensure we don't exceed requested number
            model="mistral:7b"
        )

    except Exception as e:
        logger.error(f"Error generating questions: {e}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to generate questions: {str(e)}"
        )


