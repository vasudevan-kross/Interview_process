"""
Voice Screening API endpoints.

Provides REST API for:
- Creating and managing voice screening candidates
- Bulk import via CSV/Excel
- Vapi webhook handling
- Excel export
"""

import logging
import csv
import io
import json
from fastapi import APIRouter, HTTPException, status, UploadFile, File, Depends, Request
from fastapi.responses import StreamingResponse
from typing import Optional

from app.schemas.voice_screening import (
    VoiceCandidateCreate,
    VoiceCandidateBulkCreate,
    CampaignCreateRequest,
    CampaignResponse,
    QuestionGenerationRequest,
    QuestionGenerationResponse,
)
from app.services.voice_screening_service import get_voice_screening_service
from app.services.vapi_prompt_generator import VAPIPromptGenerator
from app.services.vapi_config_builder import VAPIConfigBuilder
from app.services.vapi_recording_service import get_vapi_recording_service
from app.core.config import get_settings
from app.auth.dependencies import get_current_user_id
from app.config import settings

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/voice-screening", tags=["voice-screening"])

# Initialize campaign services
prompt_generator = VAPIPromptGenerator()
config_builder = VAPIConfigBuilder()


# ==================== CAMPAIGN ENDPOINTS ====================

@router.post("/campaigns", response_model=CampaignResponse, summary="Create a voice screening campaign")
async def create_campaign(
    campaign: CampaignCreateRequest,
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Create a new voice screening campaign with AI-generated prompts.

    Steps:
    1. Use Ollama to generate optimized VAPI system prompt
    2. Build complete VAPI configuration JSON
    3. Store in database (not VAPI platform)
    4. Return campaign details
    """
    try:
        logger.info(f"Creating campaign: {campaign.name} for role: {campaign.job_role}")

        # Step 1: Generate system prompt using Ollama
        generated_config = await prompt_generator.generate_system_prompt(
            job_role=campaign.job_role,
            custom_questions=campaign.custom_questions,
            required_fields=campaign.required_fields,
            interview_persona=campaign.interview_persona.value,
            candidate_type=campaign.candidate_type.value
        )

        # Step 2: Build complete VAPI configuration
        vapi_config = config_builder.build_vapi_config(
            system_prompt=generated_config["system_prompt"],
            structured_data_schema=generated_config["structured_data_schema"],
            candidate_type=campaign.candidate_type.value
        )

        # Step 3: Store in database
        service = get_voice_screening_service()
        campaign_data = {
            "name": campaign.name,
            "job_role": campaign.job_role,
            "description": campaign.description,
            "custom_questions": campaign.custom_questions,
            "required_fields": campaign.required_fields,
            "interview_persona": campaign.interview_persona.value,
            "candidate_type": campaign.candidate_type.value,
            "generated_system_prompt": generated_config["system_prompt"],
            "generated_schema": generated_config["structured_data_schema"],
            "vapi_config": vapi_config,
            "generation_model": "mistral:7b",
            "generation_metadata": {
                "expected_questions": generated_config.get("expected_questions", []),
                "conversation_flow": generated_config.get("conversation_flow", "")
            },
            "created_by": current_user_id
        }

        result = service.client.table("voice_screening_campaigns").insert(
            campaign_data
        ).execute()

        if not result.data:
            raise HTTPException(
                status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
                detail="Failed to create campaign"
            )

        logger.info(f"Campaign created successfully: {result.data[0]['id']}")
        return CampaignResponse(**result.data[0])

    except Exception as e:
        logger.error(f"Error creating campaign: {e}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to create campaign: {str(e)}"
        )


@router.get("/campaigns", summary="List voice screening campaigns")
async def list_campaigns(
    is_active: Optional[bool] = None,
    current_user_id: str = Depends(get_current_user_id)
):
    """List all campaigns created by current user."""
    try:
        service = get_voice_screening_service()
        query = service.client.table("voice_screening_campaigns").select("*").eq(
            "created_by", current_user_id
        ).order("created_at", desc=True)

        if is_active is not None:
            query = query.eq("is_active", is_active)

        result = query.execute()

        return {
            "campaigns": [CampaignResponse(**row) for row in result.data],
            "total": len(result.data)
        }

    except Exception as e:
        logger.error(f"Error listing campaigns: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to list campaigns: {str(e)}"
        )


@router.get("/campaigns/{campaign_id}", response_model=CampaignResponse, summary="Get campaign details")
async def get_campaign(
    campaign_id: str,
    current_user_id: str = Depends(get_current_user_id)
):
    """Get campaign details."""
    try:
        service = get_voice_screening_service()
        result = service.client.table("voice_screening_campaigns").select("*").eq(
            "id", campaign_id
        ).eq("created_by", current_user_id).single().execute()

        if not result.data:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Campaign not found"
            )

        return CampaignResponse(**result.data)

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error getting campaign: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to get campaign: {str(e)}"
        )


@router.put("/campaigns/{campaign_id}/regenerate", response_model=CampaignResponse, summary="Regenerate campaign prompt")
async def regenerate_campaign_prompt(
    campaign_id: str,
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Regenerate system prompt for existing campaign.
    Useful if user wants to try a different prompt variation.
    """
    try:
        service = get_voice_screening_service()

        # Get existing campaign
        campaign_result = service.client.table("voice_screening_campaigns").select(
            "*"
        ).eq("id", campaign_id).eq("created_by", current_user_id).single().execute()

        if not campaign_result.data:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Campaign not found"
            )

        campaign_data = campaign_result.data

        logger.info(f"Regenerating prompt for campaign: {campaign_id}")

        # Regenerate prompt
        generated_config = await prompt_generator.generate_system_prompt(
            job_role=campaign_data["job_role"],
            custom_questions=campaign_data["custom_questions"],
            required_fields=campaign_data["required_fields"],
            interview_persona=campaign_data["interview_persona"],
            candidate_type=campaign_data["candidate_type"]
        )

        # Rebuild VAPI config
        vapi_config = config_builder.build_vapi_config(
            system_prompt=generated_config["system_prompt"],
            structured_data_schema=generated_config["structured_data_schema"],
            candidate_type=campaign_data["candidate_type"]
        )

        # Update database
        import datetime
        update_data = {
            "generated_system_prompt": generated_config["system_prompt"],
            "generated_schema": generated_config["structured_data_schema"],
            "vapi_config": vapi_config,
            "generation_metadata": {
                "expected_questions": generated_config.get("expected_questions", []),
                "conversation_flow": generated_config.get("conversation_flow", "")
            },
            "updated_at": datetime.datetime.now(datetime.timezone.utc).isoformat()
        }

        result = service.client.table("voice_screening_campaigns").update(
            update_data
        ).eq("id", campaign_id).execute()

        if not result.data:
            raise HTTPException(
                status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
                detail="Failed to update campaign"
            )

        logger.info(f"Campaign prompt regenerated successfully: {campaign_id}")
        return CampaignResponse(**result.data[0])

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error regenerating campaign prompt: {e}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to regenerate prompt: {str(e)}"
        )


# ==================== CANDIDATE ENDPOINTS ====================

@router.post("/candidates", summary="Create a voice screening candidate")
async def create_candidate(
    request: VoiceCandidateCreate,
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Create a single voice screening candidate.

    BACKWARD COMPATIBLE: campaign_id is optional
    - If campaign_id provided: Uses campaign's dynamic VAPI config
    - If campaign_id is None: Uses static VAPI_ASSISTANT_ID (legacy workflow)
    """
    try:
        service = get_voice_screening_service()
        result = await service.create_candidate(
            name=request.name,
            email=request.email,
            phone=request.phone,
            is_fresher=request.is_fresher,
            campaign_id=request.campaign_id,  # NEW: Optional campaign link
            user_id=current_user_id,
        )
        return result

    except Exception as e:
        logger.error(f"Error creating voice candidate: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to create candidate: {str(e)}"
        )


@router.post("/candidates/bulk", summary="Bulk create voice candidates")
async def bulk_create_candidates(
    request: VoiceCandidateBulkCreate,
    current_user_id: str = Depends(get_current_user_id)
):
    """Bulk create voice screening candidates from a list."""
    try:
        service = get_voice_screening_service()
        candidates_data = [c.dict() for c in request.candidates]
        result = await service.bulk_create_candidates(candidates_data, current_user_id)
        return result

    except Exception as e:
        logger.error(f"Error bulk creating candidates: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to bulk create candidates: {str(e)}"
        )


@router.post("/candidates/upload", summary="Upload CSV/Excel of candidates")
async def upload_candidates_file(
    file: UploadFile = File(...),
    current_user_id: str = Depends(get_current_user_id)
):
    """
    Upload a CSV or Excel file to bulk create candidates.
    Expected columns: Name, Email, Phone, Is Fresher (true/false)
    """
    try:
        filename = file.filename or ""
        ext = filename.split(".")[-1].lower()

        content = await file.read()

        candidates = []

        if ext == "csv":
            # Parse CSV
            text = content.decode("utf-8-sig")
            reader = csv.DictReader(io.StringIO(text))
            for row in reader:
                # Normalize column names to lowercase
                row_lower = {k.strip().lower().replace(" ", "_"): v.strip() for k, v in row.items()}
                candidates.append({
                    "name": row_lower.get("name", ""),
                    "email": row_lower.get("email", ""),
                    "phone": row_lower.get("phone", "") or row_lower.get("phone_number", ""),
                    "is_fresher": row_lower.get("is_fresher", "false").lower() in ("true", "yes", "1"),
                })

        elif ext in ("xlsx", "xls"):
            # Parse Excel
            import openpyxl
            wb = openpyxl.load_workbook(io.BytesIO(content), data_only=True)
            ws = wb.active
            headers = [str(cell.value or "").strip().lower().replace(" ", "_") for cell in ws[1]]

            for row in ws.iter_rows(min_row=2, values_only=True):
                row_dict = dict(zip(headers, row))
                candidates.append({
                    "name": str(row_dict.get("name", "") or ""),
                    "email": str(row_dict.get("email", "") or ""),
                    "phone": str(row_dict.get("phone", "") or row_dict.get("phone_number", "") or ""),
                    "is_fresher": str(row_dict.get("is_fresher", "false")).lower() in ("true", "yes", "1"),
                })
        else:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"Unsupported file type: {ext}. Use CSV or Excel (.xlsx)"
            )

        # Filter out empty rows
        candidates = [c for c in candidates if c.get("name")]

        if not candidates:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="No valid candidates found in file"
            )

        service = get_voice_screening_service()
        result = await service.bulk_create_candidates(candidates, current_user_id)

        return {
            **result,
            "filename": filename,
        }

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error uploading candidates file: {e}")
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Failed to process file: {str(e)}"
        )


