# Application
APP_NAME=Interview Management API
# Set DEBUG=True for local development only — disables auth enforcement and exposes /docs
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# Database & Vector Store
DB_TYPE=supabase
VECTOR_DB=pgvector

# Supabase (handles everything: DB, Auth, Storage, Vectors)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Storage (uses Supabase Storage)
STORAGE_TYPE=supabase

# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
# qwen2.5:7b recommended — superior JSON/instruction following
DEFAULT_OLLAMA_MODEL=qwen2.5:7b
# Context window — must be >= 8192 to fit large resumes
OLLAMA_NUM_CTX=8192

# Ollama OCR Models (for fallback layers — vision model for handwritten answer sheets)
# glm-ocr is #1 ranked OCR model (94.62 on OmniDocBench), only 2.2GB, 128K context
OLLAMA_OCR_MODEL=glm-ocr
OLLAMA_FALLBACK_MODEL=glm-ocr
QUESTION_GENERATION_MODEL=qwen2.5:7b

# Local STT/TTS/VAD (Video Interview)
STT_MODEL_SIZE=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=en
TTS_PIPER_BIN=piper
TTS_PIPER_MODEL=
TTS_PIPER_CONFIG=
FFMPEG_PATH=

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,png,jpg,jpeg

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (for generating join links)
FRONTEND_URL=http://localhost:3000


# PaddleOCR - Free Handwriting OCR
# Provides 70-80% accuracy on handwritten documents, completely free and local
# Automatically downloads model on first use
PADDLEOCR_ENABLED=true
PADDLEOCR_LANG=en
# Set to 'true' for GPU acceleration (faster) or 'false' for CPU-only
# Using CPU mode (GPU support requires paddlepaddle-gpu package)
PADDLEOCR_USE_GPU=false

# OCR Strategy
# auto = Two-layer fallback: PaddleOCR library → llava:7b (Ollama vision)
# paddleocr = Use only PaddleOCR library
# ollama = Use only Ollama vision model (llava:7b)
OCR_STRATEGY=auto

# Gmail SMTP (transactional email — invite, confirmation, evaluation reports)
# Generate an App Password at: myaccount.google.com/apppasswords
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=
