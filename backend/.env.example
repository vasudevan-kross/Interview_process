# Application
APP_NAME=Interview Management API
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# Database & Vector Store
DB_TYPE=supabase
VECTOR_DB=pgvector

# Supabase (handles everything: DB, Auth, Storage, Vectors)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Storage (uses Supabase Storage)
STORAGE_TYPE=supabase

# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=mistral:7b

# Ollama OCR Models (for fallback layers)
OLLAMA_OCR_MODEL=MedAIBase/PaddleOCR-VL:0.9b
OLLAMA_FALLBACK_MODEL=glm-ocr:latest

# Redis (optional - for background tasks)
REDIS_URL=redis://localhost:6379

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,png,jpg,jpeg

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (for generating join links)
FRONTEND_URL=http://localhost:3000


# PaddleOCR - Free Handwriting OCR
# Provides 70-80% accuracy on handwritten documents, completely free and local
# Automatically downloads model on first use
PADDLEOCR_ENABLED=true
PADDLEOCR_LANG=en
# Set to 'true' for GPU acceleration (faster) or 'false' for CPU-only
# Using CPU mode (GPU support requires paddlepaddle-gpu package)
PADDLEOCR_USE_GPU=false

# OCR Strategy
# auto = Three-layer fallback: PaddleOCR → PaddleOCR-VL (Ollama) → GLM-OCR (Recommended)
# paddleocr = Use only PaddleOCR library (best for handwriting, slower on CPU)
# ollama = Use only Ollama models (skips PaddleOCR library)
OCR_STRATEGY=auto